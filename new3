9) CSV Data Analysis (awk)
#!/bin/bash

file=$1

echo "Average Salary by Department:"
awk -F, '
NR>1 {
    dept[$2]+=$3
    count[$2]++
}
END {
    for (d in dept)
        print d, ":", dept[d]/count[d]
}' $file

echo "Employees with >5 years:"
awk -F, '
NR>1 {
    split($4, d, "-")
    join_year=d[1]
    current_year=strftime("%Y")

    if ((current_year - join_year) > 5)
        print $1
}' $file




