2) Multiplication Table (1–5)
#!/bin/bash

output_file="table.txt"
> $output_file

for i in {1..5}
do
    echo "Table of $i" >> $output_file
    for j in {1..10}
    do
        echo "$i x $j = $((i*j))" >> $output_file
    done
    echo "----------------------" >> $output_file
done

cat $output_file
3) Recursive Search (.txt files)
#!/bin/bash

dir=$1
report="report.txt"
> $report

find "$dir" -type f -name "*.txt" | while read file
do
    count=$(grep -c "error" "$file")
    echo "$file : $count" >> $report
done

cat $report
