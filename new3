Backup Script
#!/bin/bash

src_dir="/home/ec2-user/data"
backup_dir="/home/ec2-user/backups"
logfile="/home/userlog"

mkdir -p $backup_dir

tar -czf "$backup_dir/backup_$(date +%F).tar.gz" -N "1 day ago" $src_dir 2>> $logfile

if [ $? -ne 0 ]; then
    echo "$(date) - Backup Failed" >> $logfile
else
    echo "$(date) - Backup Successful" >> $logfile
fi
