#!/bin/bash

read -p "Enter hostname/IP: " host
filename="network_log.txt"
logfile="/home/$USER/$filename"

ping -c 1 $host > /dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "$(date) - $host is reachable" >> $logfile
else
    echo "$(date) - $host is NOT reachable" >> $logfile
fi
5) CPU Monitoring Script
#!/bin/bash

read -p "Enter number of iterations: " n

for ((i=1; i<=n; i++))
do
    cpu=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}')

    if (( $(echo "$cpu < 10" | bc -l) )); then
        continue
    fi

    echo "Iteration $i - CPU Usage: $cpu%"

    if (( $(echo "$cpu > 90" | bc -l) )); then
        echo "Critical CPU usage! Stopping..."
        break
    fi

    sleep 2
done
6) Log File Processing (Regex + awk)
#!/bin/bash

logfile=$1

awk '
{
    ip=$1
    datetime=$2" "$3
    msg=$0

    if (ip ~ /^([0-9]{1,3}\.){3}[0-9]{1,3}$/ && msg ~ /error/i)
    {
        print "IP:", ip, "| Date-Time:", datetime, "| Message:", msg
    }
}' $logfile
✅ Set C: Automation & Advanced Processing
7) Prime Number Function
#!/bin/bash

is_prime() {
    num=$1

    if [ $num -le 1 ]; then
        return 1
    fi

    for ((i=2; i*i<=num; i++))
    do
        if (( num % i == 0 )); then
            return 1
        fi
    done

    return 0
}

read -p "Enter number: " n

if is_prime $n; then
    echo "$n is Prime"
else
    echo "$n is Not Prime"
fi





